{
  "name": "mobile-keychain",
  "version": "2.12.5",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "client": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "dep-clean": "rm -rf node_modules && npm install",
    "clean": "watchman watch-del-all &&npm run dep-clean ",
    "bump": "expo-version-bump --patch && npm run postBump",
    "bump:minor": "expo-version-bump --minor && npm run postBump",
    "postBump": "expo prebuild --clean && VERSION=$(node -p \"require('./package.json').version\") && (git commit -am \"v$VERSION\" && git tag v$VERSION && git push && git push --tags)",
    "build:android": "eas build -p android",
    "build:ios": "eas build -p ios",
    "devBuild:ios": "eas build -p ios --profile development",
    "copy:aab": "echo builds/keychain.aab | pbcopy && echo '👉 builds/keychain.aab copied to clipboard'",
    "localBuild:android": "eas build --platform android --local --output ./builds/keychain.aab",
    "localSubmit:android": "npm run copy:aab && eas submit --platform android  --profile production",
    "submit:android": "eas submit -p android --profile internal",
    "submit:ios": "source .env && EXPO_APPLE_APP_SPECIFIC_PASSWORD=$EXPO_APPLE_APP_SPECIFIC_PASSWORD eas submit -p ios --profile production",
    "crowdin:pull": "crowdin download",
    "crowdin:push": "crowdin upload sources",
    "assets:usage": "node scripts/scan-asset-usage.js",
    "assets:clean": "node scripts/clean-unused-assets.js",
    "icons:unused": "node scripts/find-unused-icons.js",
    "icons:prune": "node scripts/find-unused-icons.js --apply",
    "git:archive": "rm -rf keychain*.zip; sh -c 'uploadStash=$(git stash create); git archive -o \"keychain-$(date +%Y%m%d-%H%M%S).zip\" ${uploadStash:-HEAD}'"
  },
  "dependencies": {
